local qH = 30
local qW = 118

for i, preset in ipairs(PRESETS) do
    local row = math.ceil(i / 2) - 1
    local col = (i - 1) % 2

    local x = 8 + col * (qW + qGap)
    local y = qY + row * (qH + qGap)

    local btn = Instance.new("TextButton", fr)
    btn.Size = UDim2.new(0, qW, 0, qH)
    btn.Position = UDim2.new(0, x, 0, y)
    btn.BackgroundColor3 = preset.color
    btn.BackgroundTransparency = 0.15
    btn.Text = preset.name
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.TextTruncate = Enum.TextTruncate.AtEnd
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    -- Artist sublabel
    local sub = Instance.new("TextLabel", btn)
    sub.Size = UDim2.new(1, -4, 0, 10)
    sub.Position = UDim2.new(0, 2, 1, -12)
    sub.BackgroundTransparency = 1
    sub.Text = preset.artist
    sub.TextColor3 = Color3.fromRGB(200, 200, 200)
    sub.TextTransparency = 0.3
    sub.TextSize = 8
    sub.Font = Enum.Font.Gotham
    sub.TextXAlignment = Enum.TextXAlignment.Center

    qBtns[i] = btn
end

