-- ════════════════════════════════════════════
-- §12  START / STOP
-- ════════════════════════════════════════════
local function go()
    if _G._AD then return end
    _G._AD=true; barN=0
    task.spawn(function()
        while _G._AD do
            local s,e=pcall(PATS[pIdx].fn)
            if not s then warn("[Drum] "..tostring(e)); task.wait(0.3) end
        end
    end)
end

local function stop()
    _G._AD=false; secN="IDLE"
    pcall(function()
        for _,v in pairs(K) do VIM:SendKeyEvent(false,v,false,game) end
    end)
end

