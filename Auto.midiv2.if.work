local function rockLoop()
    secN="Rock"
    local b=barN
    if b>0 and b%16==0 then bar(rF,8,120)
    elseif b>0 and b%8==0 and RNG:NextNumber()<0.25 then bar(rC,8,120)
    elseif b%4==3 and RNG:NextNumber()<0.45 then bar(rB,8,120)
    else bar(rA,8,120) end
end

