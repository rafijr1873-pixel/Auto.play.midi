refresh()
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification",{
        Title="🥁 AutoDrum v5 Loaded!",
        Text="5 Quick MIDI songs · Tap to play!",
        Duration=4
    })
end)
