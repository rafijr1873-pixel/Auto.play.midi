-- ════════════════════════════════════════════
-- §7  CORE ENGINE
-- ════════════════════════════════════════════
local function hum(fast)
    local ms = fast and RNG:NextInteger(5,16) or RNG:NextInteger(16,45)
    return (ms/1000)*((RNG:NextInteger(0,1)==0) and 1 or -1)
end

local function press(keys, fast)
    if typeof(keys)=="EnumItem" then keys={keys} end
    for i=1,#keys do VIM:SendKeyEvent(true,keys[i],false,game) end
    task.wait(fast and RNG:NextInteger(22,42)/1000 or RNG:NextInteger(48,100)/1000)
    for i=1,#keys do VIM:SendKeyEvent(false,keys[i],false,game) end
end

local function ok() return _G._AD end

local function bar(pat,sub,bpm)
    barN=barN+1
    local base=60/bpm/(sub==16 and 4 or 2)
    local f=sub==16
    for i=1,#pat do
        if not ok() then return false end
        if pat[i] then press(pat[i],f) end
        local d=base+hum(f); if d<0.03 then d=0.03 end
        task.wait(d)
    end
    return ok()
end

local function sec(name,bars,sub,bpm)
    secN=name
    for i=1,#bars do
        if not bar(bars[i],sub,bpm) then return false end
    end
    return ok()
end

-- ════════════════════════════════════════════
-- §8  MIDI PARSER
-- ════════════════════════════════════════════
local MP = {}

function MP.parse(raw)
    if not raw or #raw<14 then return nil,"File too small" end
    local pos,len=1,#raw
    local function rb()
        if pos>len then error("EOF") end
        local b=string.byte(raw,pos); pos=pos+1; return b
    end
    local function rn(n) local v=0; for _=1,n do v=v*256+rb() end; return v end
    local function rs(n)
        if pos+n-1>len then error("EOF") end
        local s=raw:sub(pos,pos+n-1); pos=pos+n; return s
    end
    local function rvlq()
        local v,c=0,0
        repeat local b=rb(); v=v*128+(b%128); c=c+1
            if c>4 then error("VLQ") end
        until b<128; return v
    end
    local hdr=rs(4)
    if hdr~="MThd" then return nil,"Not MIDI" end
    local hl=rn(4); local fmt=rn(2); local nT=rn(2); local div=rn(2)
    if hl>6 then pos=pos+(hl-6) end
    if div>=32768 then return nil,"SMPTE not supported" end
    local ppq=div
    local notes,tempos={},{}
    for t=1,nT do
        if pos+8>len then break end
        local th=rs(4)
        if th~="MTrk" then return nil,"No MTrk #"..t end
        local tl=rn(4); local te=pos+tl
        local at,run=0,0
        while pos<te and pos<=len do
            local d=rvlq(); at=at+d
            if pos>len then break end
            local pk=string.byte(raw,pos)
            if not pk then break end
            local st
            if pk>=128 then st=rb(); if st<0xF0 then run=st end
            else st=run; if st==0 then rb(); break end end
            local hi=math.floor(st/16)
            if hi==9 then
                local n,v=rb(),rb()
                if v>0 and #notes<30000 then notes[#notes+1]={at,n,v,st%16} end
            elseif hi==8 then rb();rb()
            elseif hi==10 then rb();rb()
            elseif hi==11 then rb();rb()
            elseif hi==12 then rb()
            elseif hi==13 then rb()
            elseif hi==14 then rb();rb()
            elseif st==0xFF then
                local mt=rb(); local ml=rvlq()
                if mt==0x51 and ml>=3 then
                    local us=0; for _=1,3 do us=us*256+rb() end
                    tempos[#tempos+1]={at,us}
                    if ml>3 then pos=pos+(ml-3) end
                else pos=pos+ml end
            elseif st==0xF0 or st==0xF7 then
                local sl=rvlq(); pos=pos+sl
            else pos=te end
        end
        pos=te
    end
    if #notes==0 then return nil,"No Note-On events" end
    table.sort(notes,function(a,b) return a[1]<b[1] end)
    table.sort(tempos,function(a,b) return a[1]<b[1] end)
    return notes,tempos,ppq
end

function MP.build(notes,tempos,ppq)
    local has9=false
    for _,n in ipairs(notes) do if n[4]==9 then has9=true; break end end
    local dn={}
    for _,n in ipairs(notes) do
        if (has9 and n[4]==9) or (not has9) then
            local key=GM[n[2]]
            if key then dn[#dn+1]={tick=n[1],key=key} end
        end
    end
    if #dn==0 then return nil,0,0,0,"No drum notes" end
    if #tempos==0 or tempos[1][1]~=0 then table.insert(tempos,1,{0,500000}) end
    local tl={}; local cs,pt,ptm=0,0,500000
    for _,tc in ipairs(tempos) do
        cs=cs+(tc[1]-pt)*ptm/ppq/1e6
        tl[#tl+1]={tick=tc[1],sec=cs,tempo=tc[2]}; pt=tc[1]; ptm=tc[2]
    end
    local function t2s(tick)
        local s,p,tm=0,0,500000
        for _,t in ipairs(tl) do
            if t.tick>tick then break end
            s=t.sec; p=t.tick; tm=t.tempo
        end
        return s+(tick-p)*tm/ppq/1e6
    end
    local gr,tks={},{}
    for _,d in ipairs(dn) do
        local t=d.tick
        if not gr[t] then gr[t]={}; tks[#tks+1]=t end
        local dup=false
        for _,k in ipairs(gr[t]) do if k==d.key then dup=true; break end end
        if not dup then gr[t][#gr[t]+1]=d.key end
    end
    table.sort(tks)
    local seq={}
    for _,t in ipairs(tks) do seq[#seq+1]={time=t2s(t),keys=gr[t]} end
    local dur=seq[#seq] and seq[#seq].time or 0
    local bpm=math.floor(60e6/(tempos[1][2] or 5e5)+0.5)
    return seq,dur,bpm,#dn,nil
end

-- ════════════════════════════════════════════
-- §9  MIDI LOAD & PLAY
-- ════════════════════════════════════════════
local function fetch(url)
    local body,s,e
    s,e=pcall(function()
        if syn and syn.request then body=syn.request({Url=url,Method="GET"}).Body
        elseif http_request then body=http_request({Url=url,Method="GET"}).Body
        elseif request then body=request({Url=url,Method="GET"}).Body
        elseif httpget then body=httpget(url)
        else body=game:HttpGet(url) end
    end)
    return s and body or nil, tostring(e or "")
end

local function loadMidi(url,cb)
    if not url or url=="" then return nil,"No URL" end
    cb("⏳ Fetching...")
    local raw,fe=fetch(url)
    if not raw then return nil,"Fetch: "..(fe or "?") end
    if #raw<14 then return nil,"Too small ("..#raw.."B)" end
    cb("⏳ Parsing ("..#raw.."B)...")
    local notes,tempos,ppq=MP.parse(raw)
    if not notes then return nil,tempos end
    cb("⏳ Building ("..#notes.." notes)...")
    local seq,dur,bpm,cnt,err=MP.build(notes,tempos,ppq)
    if not seq then return nil,err end
    return {seq=seq,duration=dur,bpm=bpm,noteCount=cnt,
            fileName=url:match("[^/]+$") or "midi"}
end

local function midiLoop()
    if not midiObj or not midiObj.seq or #midiObj.seq==0 then
        secN="NO MIDI"; task.wait(1); return
    end
    secN="♫ "..currentSong
    local seq=midiObj.seq; local st=tick()
    for i=1,#seq do
        if not ok() then return end
        local tgt=st+seq[i].time; local now=tick()
        if tgt>now+0.004 then task.wait(tgt-now) end
        if not ok() then return end
        press(seq[i].keys,true)
        barN=math.floor(i/16)
    end
    secN="↻ LOOP"; task.wait(0.4)
end

