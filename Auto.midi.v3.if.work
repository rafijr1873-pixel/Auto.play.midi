    ["★ CHORUS"]=Color3.fromRGB(255,120,40),
    ["★ CHOR.2"]=Color3.fromRGB(255,80,20),
    ["⬛ BREAK"]=Color3.fromRGB(180,80,255),
    ["‼ BLAST"]=Color3.fromRGB(255,40,40),
    ["↓ FILL"]=Color3.fromRGB(255,220,60),
    ["→ LOOP"]=Color3.fromRGB(120,255,120),
    ["NO MIDI"]=Color3.fromRGB(255,80,80),
    ["↻ LOOP"]=Color3.fromRGB(120,255,180),
    ["IDLE"]=Color3.fromRGB(130,130,130),
}

-- ════════════════════════════════════════════
-- §15  HIGHLIGHT MANAGEMENT
-- ════════════════════════════════════════════
local function clearHighlights()
    for i,btn in ipairs(qBtns) do
        btn.BackgroundTransparency=0.12
        for _,c in ipairs(btn:GetChildren()) do
            if c:IsA("UIStroke") then c:Destroy() end
        end
    end
end

local function highlightSong(name)
    clearHighlights()
    for i,btn in ipairs(qBtns) do
        if PRESETS[i].name==name then
            btn.BackgroundTransparency=0
            local st=Instance.new("UIStroke",btn)
            st.Color=Color3.fromRGB(255,255,100)
            st.Thickness=2
        end
    end
end

-- ════════════════════════════════════════════
-- §16  GUI REFRESH
-- ════════════════════════════════════════════
local function refresh()
    local p=PATS[pIdx]
    patBtn.Text=p.name.."  ▸"

    if _G._AD then
        togBtn.Text="⏸  STOP"
        togBtn.BackgroundColor3=Color3.fromRGB(175,28,28)
    else
        togBtn.Text="▶  PLAY"
        togBtn.BackgroundColor3=Color3.fromRGB(0,155,50)
    end

    local bStr
    if p.name=="MIDI" and midiObj then bStr=tostring(midiObj.bpm)
    elseif p.name=="MIDI" then bStr="---"
    else bStr=tostring(p.bpm) end

    local dSec=secN
    if _G._AD then
        s1.Text=dSec.." · "..bStr.." BPM"
        s1.TextColor3=SC[dSec] or Color3.fromRGB(80,255,90)
        s2.Text="Bar: "..barN.."  │  🟢 Playing"
        s2.TextColor3=Color3.fromRGB(60,185,60)
    else
        s1.Text="⏹ "..p.name.." · "..bStr.." BPM"
        s1.TextColor3=Color3.fromRGB(130,130,130)
        s2.Text="Bar: "..barN.."  │  Tap ▶ or press P"
        s2.TextColor3=Color3.fromRGB(90,90,105)
    end

    if midiObj and not midiLoading then
        midiLbl.Text="✅ "..midiObj.noteCount.."n · "
            ..string.format("%.0fs",midiObj.duration)
            .." · "..midiObj.bpm.."BPM"
        midiLbl.TextColor3=Color3.fromRGB(80,255,80)
    elseif not midiLoading then
        midiLbl.Text="No MIDI loaded"
        midiLbl.TextColor3=Color3.fromRGB(90,90,105)
    end

    npLbl.Text = currentSong~="" and ("♪ Now: "..currentSong) or ""
end

-- Live updater
task.spawn(function()
    while gui and gui.Parent do
        pcall(refresh); task.wait(0.25)
    end
end)

-- ════════════════════════════════════════════
-- §17  TOGGLE / CYCLE
-- ════════════════════════════════════════════
local function toggle()
    if _G._AD then stop() else go() end
    refresh()
end

local function cycle()
    local was=_G._AD
    if was then stop(); task.wait(0.15) end
    if pIdx>=2 then pIdx=1 else pIdx=pIdx+1 end
    barN=0; introD=true; secN="IDLE"; currentSong=""
    clearHighlights(); refresh()
    if was then go(); refresh() end
end

-- ════════════════════════════════════════════
-- §18  SHARED MIDI LOADER
-- ════════════════════════════════════════════
local function doLoadMidi(url, songName)
    if midiLoading then return end
    midiLoading=true

    local was=_G._AD
    if was then stop(); task.wait(0.15) end

    loadBtn.Text="⏳ ..."
    loadBtn.BackgroundColor3=Color3.fromRGB(80,80,40)
    highlightSong(songName)

    task.spawn(function()
        local data, err = loadMidi(url, function(msg)
            midiLbl.Text=msg
            midiLbl.TextColor3=Color3.fromRGB(255,200,60)
        end)

        midiLoading=false
        loadBtn.Text="📥 LOAD"
        loadBtn.BackgroundColor3=Color3.fromRGB(50,50,110)

        if data then
            midiObj=data
            currentSong=songName or data.fileName
            pIdx=3; barN=0; secN="IDLE"

            midiLbl.Text="✅ "..data.noteCount.."n · "
                ..string.format("%.0fs",data.duration)
                .." · "..data.bpm.."BPM"
            midiLbl.TextColor3=Color3.fromRGB(80,255,80)

            highlightSong(songName)
            refresh()

            -- Auto-play
            task.wait(0.2)
            if not _G._AD then go(); refresh() end

            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification",{
                    Title="🥁 "..currentSong,
                    Text=data.noteCount.." notes · "..data.bpm.." BPM · Playing!",
                    Duration=3
                })
            end)
        else
            midiLbl.Text="❌ "..tostring(err):sub(1,28)
            midiLbl.TextColor3=Color3.fromRGB(255,70,70)
            clearHighlights()
        end
    end)
end

-- ════════════════════════════════════════════
-- §19  GUI TOGGLE (Minimize / Maximize)
-- ════════════════════════════════════════════
local function toggleGUI()
    guiOpen=not guiOpen
    fr.Visible=guiOpen
    miniBtn.Visible=not guiOpen
end

-- ════════════════════════════════════════════
-- §20  CONNECTIONS
-- ════════════════════════════════════════════
togBtn.MouseButton1Click:Connect(toggle)
patBtn.MouseButton1Click:Connect(cycle)
minBtn.MouseButton1Click:Connect(toggleGUI)
miniBtn.MouseButton1Click:Connect(toggleGUI)

clsBtn.MouseButton1Click:Connect(function()
    stop(); task.wait(0.1)
    if gui then gui:Destroy() end
    if kConn then kConn:Disconnect() end
    _G._AD=nil; print("[AutoDrum] 🗑️ Unloaded.")
end)

-- Quick MIDI buttons
for i,btn in ipairs(qBtns) do
    btn.MouseButton1Click:Connect(function()
        doLoadMidi(PRESETS[i].url, PRESETS[i].name)
    end)
end

-- Custom URL
loadBtn.MouseButton1Click:Connect(function()
    local url=urlBox.Text:match("^%s*(.-)%s*$")
    if url and url~="" then
        doLoadMidi(url, url:match("([^/]+)%.mid") or "Custom")
    else
        midiLbl.Text="⚠ Paste URL first!"
        midiLbl.TextColor3=Color3.fromRGB(255,180,40)
    end
end)

-- Keyboard P
kConn=UIS.InputBegan:Connect(function(i,gp)
    if gp then return end
    if i.KeyCode==Enum.KeyCode.P then toggle() end
end)

-- Mini button pulse
task.spawn(function()
    local p=0
    while gui and gui.Parent do
        if not guiOpen and _G._AD then
            p=p+1
            miniSt.Color=Color3.fromRGB(255,
                math.floor(150+100*math.sin(p*0.3)),0)
            miniBtn.BackgroundTransparency=0.15+0.15*math.sin(p*0.5)
        else
            miniSt.Color=Color3.fromRGB(255,160,0)
            miniBtn.BackgroundTransparency=0.04
        end
        task.wait(0.1)
    end
end)

-- ════════════════════════════════════════════
-- §21  STARTUP
-- ════════════════════════════════════════════
refresh()
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification",{
        Title="🥁 AutoDrum v5.1 Loaded!",
        Text=#PRESETS.." Quick MIDI songs ready!",
        Duration=4
    })
end)
print("══════════════════════════════════════════════════")
print("  🥁 AutoDrum v5.1 ✅ LOADED")
print("  ├─ Rock 120BPM │ Eyeless♫ 142BPM")
print("  ├─ "..#PRESETS.." Quick MIDI Songs:")
for i,p in ipairs(PRESETS) do
    print("  │  "..i..". "..p.name.." — "..p.artist)
end
print("  ├─ Custom MIDI URL loader")
print("  ├─ Toggle GUI: [▬] minimize / [🥁] maximize")
print("  └─ Press P or tap ▶ to start")
print("══════════════════════════════════════════════════")
