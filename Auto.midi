local SC = {
    ["Rock"]      = Color3.fromRGB(100,220,130),
    ["⚡ INTRO"]  = Color3.fromRGB(160,160,160),
    ["♫ VERSE"]   = Color3.fromRGB(100,200,255),
    ["♫ VRS.2"]   = Color3.fromRGB(80,180,230),
    ["⬆ PRE-CH"]  = Color3.fromRGB(255,200,80),
    ["⬆ PRE-C2"]  = Color3.fromRGB(255,220,60),
    ["★ CHORUS"]  = Color3.fromRGB(255,120,40),
    ["★ CHOR.2"]  = Color3.fromRGB(255,80,20),
    ["⬛ BREAK"]  = Color3.fromRGB(180,80,255),
    ["‼ BLAST"]   = Color3.fromRGB(255,40,40),
    ["↓ FILL"]    = Color3.fromRGB(255,220,60),
    ["→ LOOP"]    = Color3.fromRGB(120,255,120),
    ["MIDI ♫"]    = Color3.fromRGB(100,180,255),
    ["MIDI ↻"]    = Color3.fromRGB(120,255,120),
    ["NO MIDI"]   = Color3.fromRGB(255,80,80),
    ["IDLE"]      = Color3.fromRGB(130,130,130),
}

-- ════════════════════════════════════════════════════
-- §15  GUI REFRESH
-- ════════════════════════════════════════════════════
local function refresh()
    local p = PATS[pIdx]
    patBtn.Text = p.name .. "  ▸"

    -- Play/Stop button
    if _G._AD then
        togBtn.Text = "⏸  STOP"
        togBtn.BackgroundColor3 = Color3.fromRGB(175,28,28)
    else
        togBtn.Text = "▶  PLAY"
        togBtn.BackgroundColor3 = Color3.fromRGB(0,155,50)
    end

    -- BPM display
    local bpmStr
    if p.name == "MIDI" and midiObj then
        bpmStr = tostring(midiObj.bpm)
    elseif p.name == "MIDI" then
        bpmStr = "---"
    else
        bpmStr = tostring(p.bpm)
    end

    -- Status Line 1
    if _G._AD then
        s1.Text = secN .. " · " .. bpmStr .. " BPM"
        s1.TextColor3 = SC[secN] or Color3.fromRGB(80,255,90)
    else
        s1.Text = "⏹ " .. p.name .. " · " .. bpmStr .. " BPM"
        s1.TextColor3 = Color3.fromRGB(130,130,130)
    end

    -- Status Line 2
    if _G._AD then
        s2.Text = "Bar: " .. barN .. "  │  🟢 Playing"
        s2.TextColor3 = Color3.fromRGB(60,185,60)
    else
        s2.Text = "Bar: " .. barN .. "  │  Tap ▶ or press P"
        s2.TextColor3 = Color3.fromRGB(90,90,105)
    end

    -- MIDI label
    if midiObj then
        midiLbl.Text = "✅ " .. midiObj.noteCount .. " notes · "
            .. string.format("%.1fs", midiObj.duration)
        midiLbl.TextColor3 = Color3.fromRGB(80,255,80)
    elseif midiLoading then
        -- keep current text
    else
        midiLbl.Text = "No MIDI loaded"
        midiLbl.TextColor3 = Color3.fromRGB(90,90,100)
    end

    -- URL box border color
    if pIdx == 3 then
        urlS.Color = Color3.fromRGB(100,100,200)
        loadBtn.BackgroundColor3 = Color3.fromRGB(65,65,140)
    else
        urlS.Color = Color3.fromRGB(50,50,80)
        loadBtn.BackgroundColor3 = Color3.fromRGB(45,45,90)
    end
end

-- Live updater
task.spawn(function()
    while gui and gui.Parent do
        pcall(refresh)
        task.wait(0.22)
    end
end)

-- ════════════════════════════════════════════════════
-- §16  TOGGLE & PATTERN CYCLE
-- ════════════════════════════════════════════════════
local function toggle()
    if _G._AD then stop() else go() end
    refresh()
end

local function cycle()
    local was = _G._AD
    if was then stop(); task.wait(0.15) end
    pIdx = pIdx % #PATS + 1
    barN = 0; introD = true; secN = "IDLE"
    refresh()
    if was then go(); refresh() end
end

-- ════════════════════════════════════════════════════
-- §17  MIDI LOAD HANDLER
-- ════════════════════════════════════════════════════
local function onLoadMidi()
    if midiLoading then return end

    local url = urlBox.Text
    if not url or url:match("^%s*$") then
        midiLbl.Text = "⚠ Paste URL first!"
        midiLbl.TextColor3 = Color3.fromRGB(255,180,40)
        return
    end

    -- Trim whitespace
    url = url:match("^%s*(.-)%s*$")

    midiLoading = true
    loadBtn.Text = "⏳ ..."
    loadBtn.BackgroundColor3 = Color3.fromRGB(80,80,40)

    task.spawn(function()
        local data, err = loadMidiFromURL(url, function(msg)
            midiLbl.Text = "⏳ " .. msg
            midiLbl.TextColor3 = Color3.fromRGB(255,200,60)
        end)

        midiLoading = false

        if data then
            midiObj = data

            -- Auto-switch to MIDI pattern
            local was = _G._AD
            if was then stop(); task.wait(0.12) end
            pIdx = 3  -- MIDI
            barN = 0
            secN = "IDLE"

            loadBtn.Text = "📥  LOAD"
            midiLbl.Text = "✅ " .. data.noteCount .. " notes · "
                .. string.format("%.1fs", data.duration)
                .. " · " .. data.bpm .. "BPM"
            midiLbl.TextColor3 = Color3.fromRGB(80,255,80)
            refresh()

            if was then go(); refresh() end

            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification",{
                    Title="🥁 MIDI Loaded!",
                    Text=data.noteCount.." drum notes · "..data.bpm.." BPM",
                    Duration=3
                })
            end)
        else
            loadBtn.Text = "📥  LOAD"
            midiLbl.Text = "❌ " .. tostring(err):sub(1, 35)
            midiLbl.TextColor3 = Color3.fromRGB(255,70,70)
        end
    end)
end

-- ════════════════════════════════════════════════════
-- §18  CONNECTIONS
-- ════════════════════════════════════════════════════
togBtn.MouseButton1Click:Connect(toggle)
patBtn.MouseButton1Click:Connect(cycle)
loadBtn.MouseButton1Click:Connect(onLoadMidi)
cb.MouseButton1Click:Connect(function()
    stop(); task.wait(0.1)
    if gui then gui:Destroy() end
    if kConn then kConn:Disconnect() end
    _G._AD = nil
    print("[AutoDrum] 🗑️ Unloaded.")
end)

kConn = UIS.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Enum.KeyCode.P then toggle() end
end)

