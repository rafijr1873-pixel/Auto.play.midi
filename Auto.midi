    [37]=K.SnS,                               -- Side Stick
    [38]=K.Sn,[39]=K.Sn,[40]=K.Sn,          -- Snare + Clap
    [41]=K.T3,[43]=K.T3,                     -- Floor Tom
    [42]=K.HC,[44]=K.HC,                     -- Closed HH / Pedal
    [45]=K.T2,[47]=K.T2,                     -- Mid Tom
    [46]=K.HO,                                -- Open HH
    [48]=K.T1,[50]=K.T1,                     -- High Tom
    [49]=K.CL,[57]=K.CR,                     -- Crash 1 & 2
    [51]=K.Rd,[59]=K.Rd,                     -- Ride 1 & 2
    [52]=K.Ch,                                -- China
    [53]=K.RB,                                -- Ride Bell
    [54]=K.HC,                                -- Tambourine → HH
    [55]=K.Sp,                                -- Splash
    [56]=K.Cb,                                -- Cowbell
    [58]=K.Sp,                                -- Vibraslap → Splash
